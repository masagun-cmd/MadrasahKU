# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_SHEETS_ID: The ID of the Google Sheet used as a database.
GOOGLE_SHEETS_ID=""

# GOOGLE_SERVICE_ACCOUNT_EMAIL: The email of the service account.
GOOGLE_SERVICE_ACCOUNT_EMAIL=""

# GOOGLE_PRIVATE_KEY: The private key of the service account (base64 encoded or raw).
GOOGLE_PRIVATE_KEY=""

# TWILIO_ACCOUNT_SID: Your Twilio Account SID
TWILIO_ACCOUNT_SID=""

# TWILIO_AUTH_TOKEN: Your Twilio Auth Token
TWILIO_AUTH_TOKEN=""

# TWILIO_WHATSAPP_NUMBER: Your Twilio WhatsApp Number (e.g., whatsapp:+14155238886)
TWILIO_WHATSAPP_NUMBER=""
